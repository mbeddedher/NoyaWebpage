generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categories {
  id               Int          @id @default(autoincrement())
  name             String       @db.VarChar(255)
  description      String?
  parent_id        Int?
  created_at       DateTime?    @default(now()) @db.Timestamp(6)
  updated_at       DateTime?    @default(now()) @db.Timestamp(6)
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction, map: "fk_parent_category")
  other_categories categories[] @relation("categoriesTocategories")
  products         products[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model comments {
  id             Int        @id @default(autoincrement())
  product_id     Int
  user_id        Int
  parent_id      Int?
  content        String
  star           Int?
  created_at     DateTime?  @default(now()) @db.Timestamp(6)
  updated_at     DateTime?  @default(now()) @db.Timestamp(6)
  comments       comments?  @relation("commentsTocomments", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comment_parent")
  other_comments comments[] @relation("commentsTocomments")
  products       products   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comment_product")
  users          users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comment_user")
}

model crafted_products {
  id                                                       Int       @id @default(autoincrement())
  parent_product_id                                        Int
  component_product_id                                     Int
  quantity                                                 Decimal   @default(1) @db.Decimal(10, 2)
  created_at                                               DateTime? @default(now()) @db.Timestamp(6)
  updated_at                                               DateTime? @default(now()) @db.Timestamp(6)
  converted_currency                                       String?   @db.VarChar(3)
  products_crafted_products_component_product_idToproducts products  @relation("crafted_products_component_product_idToproducts", fields: [component_product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_component_product")
  products_crafted_products_parent_product_idToproducts    products  @relation("crafted_products_parent_product_idToproducts", fields: [parent_product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_parent_product")
}

model currency_rates {
  id            Int      @id @default(autoincrement())
  from_currency String   @db.VarChar(3)
  to_currency   String   @db.VarChar(3)
  rate          Decimal  @db.Decimal(20, 6)
  date          DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @db.Timestamp(6)

  @@unique([from_currency, to_currency, date])
  @@index([from_currency, to_currency], map: "idx_currency_rates_currencies")
  @@index([date], map: "idx_currency_rates_date")
}

model images {
  id              Int             @id @default(autoincrement())
  display_id      Int
  url             String
  is_primary      Boolean?        @default(false)
  display_type    image_type      @default(gallery)
  alt_text        String?         @db.VarChar(255)
  order_index     Int?            @default(0)
  file_size       Int?
  resolution      String?         @db.VarChar(50)
  format          String?         @db.VarChar(10)
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  updated_at      DateTime?       @default(now()) @db.Timestamp(6)
  product_display product_display @relation(fields: [display_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_display_image")
}

model linked_prices {
  id                                                    Int       @id @default(autoincrement())
  parent_product_id                                     Int
  component_product_id                                  Int
  created_at                                            DateTime? @default(now()) @db.Timestamp(6)
  updated_at                                            DateTime? @default(now()) @db.Timestamp(6)
  currency                                              String?   @db.VarChar(3)
  products_linked_prices_component_product_idToproducts products  @relation("linked_prices_component_product_idToproducts", fields: [component_product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_component_product")
  products_linked_prices_parent_product_idToproducts    products  @relation("linked_prices_parent_product_idToproducts", fields: [parent_product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_parent_product")
}

model multi_currency_prices {
  id         Int      @id @default(autoincrement())
  product_id Int
  currency   String   @db.VarChar(3)
  price      Decimal  @db.Decimal(20, 2)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, currency])
}

model order_items {
  id         Int      @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  price      Decimal  @db.Decimal(10, 2)
  total      Decimal? @db.Decimal(10, 2)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order_item_order")
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order_item_product")
}

model orders {
  id                  Int            @id @default(autoincrement())
  user_id             Int
  order_date          DateTime?      @default(now()) @db.Timestamp(6)
  status              order_status?  @default(pending)
  total_amount        Decimal        @db.Decimal(10, 2)
  currency            String         @db.Char(3)
  payment_method      String?        @db.VarChar(50)
  shipping_address_id Int
  created_at          DateTime?      @default(now()) @db.Timestamp(6)
  updated_at          DateTime?      @default(now()) @db.Timestamp(6)
  order_items         order_items[]
  user_addresses      user_addresses @relation(fields: [shipping_address_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order_address")
  users               users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order_user")
}

model package_options {
  id           Int                              @id @default(autoincrement())
  status       package_option_status_type       @default(active)
  product_id   Int
  count        Int
  discount     Decimal?                         @default(0) @db.Decimal(4, 2)
  stock_status package_option_stock_status_type @default(divide)
  name         String?                          @db.VarChar(50)
  order_index  Int?
  products     products                         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model prices {
  id                Int             @id @default(autoincrement())
  product_id        Int
  price             Decimal         @db.Decimal(10, 2)
  currency          String          @db.Char(3)
  is_component      Boolean?        @default(false)
  cost              Decimal         @db.Decimal(10, 2)
  vat               Decimal         @db.Decimal(5, 2)
  profit            Decimal         @db.Decimal(5, 2)
  discount          Decimal         @default(0) @db.Decimal(5, 2)
  supplier_discount Decimal         @default(0) @db.Decimal(5, 2)
  has_difference    Boolean?        @default(false)
  is_multi          Boolean?        @default(false)
  difference_type   String?         @db.VarChar(20)
  difference_value  Decimal?        @db.Decimal(10, 2)
  link_type         link_type_enum?
  is_linked         Boolean?        @default(false)
  products          products        @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_product_price")
}

model product_display {
  id               Int                 @id @default(autoincrement())
  status           display_status_type
  name             String              @db.VarChar(255)
  brand            String?             @db.VarChar(255)
  ranking          Decimal?            @default(0) @db.Decimal(3, 2)
  description      Json?
  has_variants     Boolean?            @default(false)
  category_id      Int
  keywords         String[]
  size_array       String[]            @default([])
  popularity_score Float?              @default(0)
  created_at       DateTime?           @default(now()) @db.Timestamp(6)
  updated_at       DateTime?           @default(now()) @db.Timestamp(6)
  images           images[]
  cart_images      cart_images[]
  web_categories   web_categories      @relation(fields: [category_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  product_variants product_variants[]
}

model product_variants {
  id                  Int                         @id @default(autoincrement())
  product_id          Int
  display_id          Int
  size                String                      @db.VarChar(50)
  has_package_options Boolean?                    @default(true)
  order_index         Int
  status              package_option_status_type? @default(active)
  product_display     product_display             @relation(fields: [display_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products            products                    @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, size])
}

model products {
  id                                                               Int                     @id @default(autoincrement())
  is_active                                                        Boolean?                @default(true)
  is_onsite                                                        Boolean?                @default(false)
  is_crafted                                                       Boolean?                @default(false)
  sku                                                              String                  @unique @db.VarChar(50)
  name                                                             String                  @db.VarChar(255)
  category_id                                                      Int
  brand                                                            String                  @db.VarChar(50)
  supplier_id                                                      Int
  dimensions                                                       String?                 @db.VarChar(50)
  created_at                                                       DateTime?               @default(now()) @db.Timestamp(6)
  updated_at                                                       DateTime?               @default(now()) @db.Timestamp(6)
  comments                                                         comments[]
  crafted_products_crafted_products_component_product_idToproducts crafted_products[]      @relation("crafted_products_component_product_idToproducts")
  crafted_products_crafted_products_parent_product_idToproducts    crafted_products[]      @relation("crafted_products_parent_product_idToproducts")
  linked_prices_linked_prices_component_product_idToproducts       linked_prices[]         @relation("linked_prices_component_product_idToproducts")
  linked_prices_linked_prices_parent_product_idToproducts          linked_prices[]         @relation("linked_prices_parent_product_idToproducts")
  multi_currency_prices                                            multi_currency_prices[]
  order_items                                                      order_items[]
  package_options                                                  package_options[]
  prices                                                           prices[]
  product_variants                                                 product_variants[]
  categories                                                       categories              @relation(fields: [category_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  suppliers                                                        suppliers               @relation(fields: [supplier_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  stocks                                                           stocks[]
}

model stocks {
  id               Int                          @id @default(autoincrement())
  product_id       Int
  stock_status     stock_status_type?           @default(limited)
  quantity         Int?                         @default(0)
  unit             unit_type
  min_stock        Int?
  package_quantity Int?                         @default(1)
  is_linked        Boolean?                     @default(false)
  is_component     Boolean?                     @default(false)
  created_at       DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at       DateTime?                    @default(now()) @db.Timestamp(6)
  arrival_date     String?                      @db.VarChar(50)
  arrival_type     stock_arrival_interval_type? @default(unknown)
  products         products                     @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_product_stock")
}

model suppliers {
  id           Int        @id @default(autoincrement())
  name         String     @db.VarChar(255)
  contact_name String?    @db.VarChar(255)
  phone        String?    @db.VarChar(20)
  email        String?    @db.VarChar(255)
  address      String?
  city         String?    @db.VarChar(100)
  country      String?    @db.VarChar(100)
  postal_code  String?    @db.VarChar(20)
  website      String?    @db.VarChar(255)
  created_at   DateTime?  @default(now()) @db.Timestamp(6)
  updated_at   DateTime?  @default(now()) @db.Timestamp(6)
  products     products[]
}

model user_addresses {
  id          Int       @id @default(autoincrement())
  user_id     Int
  address     String
  city        String    @db.VarChar(50)
  state       String?   @db.VarChar(50)
  postal_code String?   @db.VarChar(20)
  country     String    @db.VarChar(50)
  is_primary  Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  orders      orders[]
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_address")
}

model users {
  id             Int              @id @default(autoincrement())
  first_name     String           @db.VarChar(50)
  last_name      String           @db.VarChar(50)
  email          String           @unique @db.VarChar(100)
  password_hash  String
  phone_number   String?          @db.VarChar(20)
  is_active      Boolean?         @default(true)
  role           user_role_type   @default(customer)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  comments       comments[]
  orders         orders[]
  user_addresses user_addresses[]
}

model web_categories {
  id                   Int               @id @default(autoincrement())
  name                 String            @db.VarChar(255)
  description          String?
  parent_id            Int?
  created_at           DateTime?         @default(now()) @db.Timestamp(6)
  updated_at           DateTime?         @default(now()) @db.Timestamp(6)
  product_display      product_display[]
  web_categories       web_categories?   @relation("web_categoriesToweb_categories", fields: [parent_id], references: [id], onUpdate: NoAction, map: "fk_parent_category")
  other_web_categories web_categories[]  @relation("web_categoriesToweb_categories")
}

model cart_images {
  id          Int             @id @default(autoincrement())
  display_id  Int
  url         String
  width       Int
  height      Int
  format      String?         @db.VarChar(10)
  is_primary  Boolean?        @default(false)
  order_index Int?            @default(0)
  created_at  DateTime?       @default(now()) @db.Timestamp(6)
  updated_at  DateTime?       @default(now()) @db.Timestamp(6)
  display     product_display @relation(fields: [display_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum differece_type_enum {
  discount
  profit
}

enum display_status_type {
  active
  diactive
}

enum image_type {
  thumbnail
  gallery
  zoomed
}

enum link_type_enum {
  cost
  cost_vat @map("cost-vat")
  price
  manual
}

enum order_status {
  pending
  processing
  shipped
  delivered
  canceled
  returned
}

enum package_option_status_type {
  active
  not_active   @map("not active")
  out_of_stock @map("out of stock")
}

enum package_option_stock_status_type {
  divide
  seperate
  infinite
}

enum stock_arrival_interval_type {
  interval
  weeky
  monthly
  date
  inhereted
  unknown
}

enum stock_status_type {
  limited
  unlimited
  locked
  infinite
}

enum unit_type {
  m
  cm
  mm
  inch
  m2
  kg
  g
  piece
  pack
}

enum user_role_type {
  admin
  customer
  servicer
  guest
}
